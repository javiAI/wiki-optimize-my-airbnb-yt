# Configuration Template for LLM Wiki Automation
# Copy to .env and customize for your setup (gitignored automatically)

# VAULT CONFIGURATION
VAULT_PATH=~/Dev/obsidian_vaults/optimize-my-airbnb-yt
VAULT_NAME=optimize-my-airbnb-yt

# AUTOMATION
AUTOMATION_ENABLED=true
LOG_LEVEL=info
AUTO_APPROVE_THRESHOLD=0.90

# EXTERNAL TOOLS (for ingest scripts)
YT_DLP_PATH=$(which yt-dlp)
JQ_PATH=$(which jq)
PYTHON3_PATH=$(which python3)

# SAFETY
REQUIRE_APPROVAL_FOR_PHASE=true
DRY_RUN=false
