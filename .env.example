# WikiForge — Environment Configuration
# Copy to .env and customize. (.env is gitignored)
#
# VAULT_NAME identifies which config to use from configs/{name}.yaml
# This is the only required variable for most scripts.

VAULT_NAME=my-vault

# LEGACY: VAULT_PATH is still supported if you have vault.yaml inside the vault directory.
# New vaults should use VAULT_NAME + configs/{name}.yaml instead.
# VAULT_PATH=~/Dev/obsidian_vaults/my-vault

# AUTOMATION
AUTOMATION_ENABLED=true
LOG_LEVEL=info

# EXTERNAL TOOLS (auto-detected if on PATH)
# YT_DLP_PATH=$(which yt-dlp)
# JQ_PATH=$(which jq)
# PYTHON3_PATH=$(which python3)
