# WikiForge unified configuration (per-vault, local to developer)
# See docs/CONFIG_SCHEMA.md for full schema

# Local selections (each developer sets their own)
active_vault: {{ vault_name }}
active_lang: {{ default_lang }}

# === RETRIEVAL BACKEND ===
# These settings control how atoms are retrieved for queries

retrieval:
  # Backend selection: "bm25" (keyword, $0), "llm" (semantic, costs tokens)
  backend: bm25

  # === BM25 Configuration ===
  bm25:
    enabled: true
    topic_boost: 3.0      # Multiplier for topic matches (1.0-10.0)
    claim_boost: 2.0      # Multiplier for claim matches (1.0-5.0)

  # === LLM Backend (optional) ===
  llm:
    enabled: false        # Set to true to use LLM as primary backend

    # Fallback mode: use BM25 primary, LLM only when ambiguous
    fallback:
      enabled: false      # Set to true to enable LLM fallback
      trigger: "bm25_confidence"
      threshold: 1.5      # Use LLM if top1/top2 < threshold (1.0-3.0)
