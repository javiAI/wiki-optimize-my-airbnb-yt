{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-file-write.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/on-config-change.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-bash-complete.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-session-stop.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "_documentation": {
    "purpose": "WikiForge v2 hook-driven pipeline + optimization test workflow notification",
    "wiki_hooks": {
      "on-file-write.sh": "raw/{lang}/ writes → queue pending-atoms.txt; wiki/{lang}/ writes → auto-link + qa + optional auto_propagate (re-atomize at locator into other enabled langs)",
      "on-config-change.sh": "vault.yaml writes → validate config",
      "on-bash-complete.sh": "ingest.sh completion → update pending-atoms queue",
      "on-session-stop.sh": "session end → incremental vault-agent.py audit if files changed",
      "on-session-start.sh": "session start → notify if pending-atoms queue is non-empty"
    }
  }
}
